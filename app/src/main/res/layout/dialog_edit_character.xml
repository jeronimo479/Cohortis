<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Name"
                app:expandedHintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <CheckBox
                android:id="@+id/cbIsPC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="PC" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llClassAttacks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilClassLevel"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Class(es) and Level(s)"
                app:expandedHintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etClassLevel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAttacksCycle"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:hint="#"
                app:expandedHintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAttacksCycle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:gravity="center"
                    android:text="1"
                    android:textStyle="bold"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llHitDiceRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilHitDice"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Hit Dice (HD)"
                app:expandedHintEnabled="false">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHitDice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageButton
                android:id="@+id/btnRerollHp"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_rotate"
                android:contentDescription="Reroll HP" />
        </LinearLayout>

        <!-- HP Full Stepper -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HP Full" android:textSize="12sp" android:layout_marginTop="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <Button android:id="@+id/btnHpFullMinus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" style="?attr/materialButtonOutlinedStyle"/>
            <EditText android:id="@+id/etHpFull" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:inputType="numberSigned" android:gravity="center" android:text="1"/>
            <Button android:id="@+id/btnHpFullPlus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" style="?attr/materialButtonOutlinedStyle"/>
        </LinearLayout>

        <!-- HP Current Stepper -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HP Current" android:textSize="12sp" android:layout_marginTop="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <Button android:id="@+id/btnHpCurrentMinus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" style="?attr/materialButtonOutlinedStyle"/>
            <EditText android:id="@+id/etHpCurrent" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:inputType="numberSigned" android:gravity="center" android:text="1"/>
            <Button android:id="@+id/btnHpCurrentPlus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" style="?attr/materialButtonOutlinedStyle"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
            <!-- THAC0 Stepper -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="THAC0" android:textSize="12sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <Button android:id="@+id/btnThac0Minus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" style="?attr/materialButtonOutlinedStyle" android:minWidth="48dp" android:padding="0dp"/>
                    <EditText android:id="@+id/etThac0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:inputType="number" android:gravity="center" android:text="20"/>
                    <Button android:id="@+id/btnThac0Plus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" style="?attr/materialButtonOutlinedStyle" android:minWidth="48dp" android:padding="0dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- AC Stepper -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Armor Class (AC)" android:textSize="12sp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <Button android:id="@+id/btnAcMinus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" style="?attr/materialButtonOutlinedStyle" android:minWidth="48dp" android:padding="0dp"/>
                    <EditText android:id="@+id/etArmorClass" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:inputType="numberSigned" android:gravity="center" android:text="10"/>
                    <Button android:id="@+id/btnAcPlus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" style="?attr/materialButtonOutlinedStyle" android:minWidth="48dp" android:padding="0dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Damage Rolls (e.g. 1d8, 2x2d4+1)"
            app:expandedHintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDamageRolls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Special Detections"
            app:expandedHintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSpecialDetections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Special Attacks"
            app:expandedHintEnabled="false">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSpecialAttacks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
