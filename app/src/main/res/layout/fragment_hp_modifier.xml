<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/windowBackground"
    android:padding="24dp">

    <!-- Member Name -->
    <TextView
        android:id="@+id/tvMemberName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Box 1 Container (Action Button with Label on Border) -->
    <FrameLayout
        android:id="@+id/flBox1Container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvMemberName">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBox1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:textSize="20sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeWidth="2dp" />

        <TextView
            android:id="@+id/tvBox1Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="?android:attr/windowBackground"
            android:paddingHorizontal="4dp"
            android:textSize="12sp"
            android:textStyle="bold"
            android:alpha="0.8" />
    </FrameLayout>

    <!-- Row 2: Just text, centered (Value : Label) -->
    <TextView
        android:id="@+id/tvBox2Display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        app:layout_constraintTop_toBottomOf="@id/flBox1Container" />

    <!-- Box 3 (Accumulator): Centered, No Label -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBox3"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="200dp"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:text="0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/holo_blue_dark"
        app:strokeColor="@android:color/holo_blue_dark"
        app:cornerRadius="12dp"
        app:strokeWidth="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvBox2Display"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Keypad -->
    <GridLayout
        android:id="@+id/glKeypad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:columnCount="3"
        app:layout_constraintTop_toBottomOf="@id/btnBox3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button android:id="@+id/btn7" android:text="7" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn8" android:text="8" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn9" android:text="9" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>

        <Button android:id="@+id/btn4" android:text="4" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn5" android:text="5" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn6" android:text="6" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>

        <Button android:id="@+id/btn1" android:text="1" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn2" android:text="2" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btn3" android:text="3" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>

        <Button android:id="@+id/btnMinus" android:text="-" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp" android:backgroundTint="@android:color/holo_red_dark" android:textColor="@android:color/white" android:textSize="22sp"/>
        <Button android:id="@+id/btn0" android:text="0" style="?attr/materialButtonOutlinedStyle" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp"/>
        <Button android:id="@+id/btnPlus" android:text="+" android:layout_width="85dp" android:layout_height="56dp" android:layout_margin="2dp" android:backgroundTint="@android:color/holo_green_dark" android:textColor="@android:color/white" android:textSize="22sp"/>

        <Button android:id="@+id/btnClear"
            android:text="CLEAR"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_columnSpan="3"
            android:layout_margin="2dp"
            android:layout_gravity="fill_horizontal"
            android:textColor="@android:color/darker_gray" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
