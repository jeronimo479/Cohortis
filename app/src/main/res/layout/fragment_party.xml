<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvParties"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="4dp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/emptyPartyBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:visibility="gone"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="12dp">

        <!-- The Box Border -->
        <View
            android:id="@+id/emptyBoxBorder"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_party_box"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="No active parties.\nTap the arrow to load one."
            android:textColor="#888888"
            app:layout_constraintBottom_toBottomOf="@id/emptyBoxBorder"
            app:layout_constraintTop_toTopOf="@id/emptyBoxBorder" />

        <!-- The Header straddling the line -->
        <LinearLayout
            android:id="@+id/emptyPartyHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:background="?android:attr/windowBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            app:layout_constraintBottom_toTopOf="@+id/emptyBoxBorder"
            app:layout_constraintStart_toStartOf="@+id/emptyBoxBorder"
            app:layout_constraintTop_toTopOf="@+id/emptyBoxBorder">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="2dp"
                android:src="@drawable/ic_dropdown_arrow"
                android:tint="?android:attr/textColorSecondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Party"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- The (+) button straddling the line -->
        <ImageButton
            android:id="@+id/emptyAddMember"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="20dp"
            android:background="?android:attr/windowBackground"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="Open Member Library"
            android:padding="2dp"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toTopOf="@+id/emptyBoxBorder"
            app:layout_constraintEnd_toEndOf="@+id/emptyBoxBorder"
            app:layout_constraintTop_toTopOf="@+id/emptyBoxBorder"
            app:tint="?android:attr/textColorSecondary" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>