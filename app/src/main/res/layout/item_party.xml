<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- The Box Content Container -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_party_box"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCharacters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="2dp"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>

    <!-- Footer descriptions straddling the BOTTOM line -->
    <!-- Weights must match item_character.xml Column weights -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/contentContainer"
        app:layout_constraintTop_toBottomOf="@+id/contentContainer"
        app:layout_constraintStart_toStartOf="@+id/contentContainer"
        app:layout_constraintEnd_toEndOf="@+id/contentContainer">

        <!-- Name Hint -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.8">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="2dp" />
        </FrameLayout>

        <!-- Damage Hint -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.2">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Dmg"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="2dp" />
        </FrameLayout>

        <!-- TH0/AC Hints -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.6"
            android:orientation="horizontal"
            android:gravity="center_vertical|end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="20dp"
                android:gravity="center"
                android:text="TH0"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="1dp" />
            <!-- Space matching star width (12dp) + margins (2dp) -->
            <View
                android:layout_width="14dp"
                android:layout_height="1dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="20dp"
                android:gravity="center"
                android:text="AC"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="1dp" />
        </LinearLayout>

        <!-- HP Hint -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="HP"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="2dp" />
        </FrameLayout>

        <!-- LVL Hint -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="LVL"
                android:textSize="8sp"
                android:textColor="#888888"
                android:background="?android:attr/windowBackground"
                android:paddingHorizontal="2dp" />
        </FrameLayout>
    </LinearLayout>

    <!-- The Header straddling the TOP left line -->
    <LinearLayout
        android:id="@+id/partyHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:background="?android:attr/windowBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:layout_constraintBottom_toTopOf="@+id/contentContainer"
        app:layout_constraintStart_toStartOf="@+id/contentContainer"
        app:layout_constraintTop_toTopOf="@+id/contentContainer">

        <ImageView
            android:id="@+id/ivDropdown"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="2dp"
            android:src="@drawable/ic_dropdown_arrow"
            android:tint="?android:attr/textColorSecondary" />

        <TextView
            android:id="@+id/tvPartyName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Party Name"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- The (+) button straddling the TOP right line -->
    <ImageButton
        android:id="@+id/btnAddMember"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="24dp"
        android:background="?android:attr/windowBackground"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Open Member Library"
        android:padding="2dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toTopOf="@+id/contentContainer"
        app:layout_constraintEnd_toEndOf="@+id/contentContainer"
        app:layout_constraintTop_toTopOf="@+id/contentContainer"
        app:tint="?android:attr/textColorSecondary" />

</androidx.constraintlayout.widget.ConstraintLayout>